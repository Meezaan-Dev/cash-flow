{
	"firestore": {
		"rules": "firestore.rules"
	},
	"functions": [
		{
			"source": "functions",
			"predeploy": [
				"npm --prefix \"$RESOURCE_DIR\" run lint",
				"npm --prefix \"$RESOURCE_DIR\" run build"
			],
			"codebase": "default"
		}
	],
	"emulators": {
		"auth": { "port": 9099 },
		"firestore": { "port": 8080 },
		"functions": { "port": 5001 },
		"ui": { "enabled": true }
	}
}
